# LLM Provider: "anthropic" (default), "azure", or "openai"
LLM_PROVIDER=azure

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# For stronger document QA, use your best chat/reasoning deployment if available.
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- Anthropic (alternative) ---
# ANTHROPIC_API_KEY=your-anthropic-key

# --- OpenAI (alternative) ---
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4.1-mini

# --- DocStruct settings ---
# DOCSTRUCT_MIN_CONFIDENCE=0.75
# DOCSTRUCT_BATCH_SIZE=5
# DOCSTRUCT_PARALLEL=true
# DOCSTRUCT_MAX_WORKERS=4
# DOCSTRUCT_AGENT_MODEL=gpt-4.1-mini
# DOCSTRUCT_AGENT_MAX_TOKENS=4096
# DOCSTRUCT_AGENT_TEMPERATURE=0.0
# DOCSTRUCT_AGENT_TIMEOUT=30
# DOCSTRUCT_AGENT_RETRY_COUNT=3
# DOCSTRUCT_AGENT_RETRY_DELAY=1
# DOCSTRUCT_AGENT_PROVIDER=azure

# Neo4j Configuration (005-neo4j-hybrid-search)
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=none
NEO4J_MAX_POOL_SIZE=50
NEO4J_READINESS_RETRIES=30
NEO4J_READINESS_BACKOFF_BASE=1.0

# Embedding Configuration (Provider Selection)
# Options: "openai" or "cohere"
EMBEDDING_PROVIDER=openai

# Embedding Models
# OpenAI: "text-embedding-3-small" (1536 dimensions) or "text-embedding-3-large" (3072 dimensions)
# Cohere: "embed-english-v3.0" (1024 dimensions)
EMBEDDING_MODEL=text-embedding-3-small

# Embedding Dimensions (auto-detected from model; can override if needed)
# OpenAI text-embedding-3-small: 1536
# Cohere embed-english-v3.0: 1024
# EMBEDDING_DIMENSIONS=1536

# Retrieval Configuration
RETRIEVAL_MAX_CANDIDATES=6
RETRIEVAL_ENABLE_GRAPH=true
RETRIEVAL_ENABLE_FULLTEXT=true
RETRIEVAL_ENABLE_VECTOR=true

# API Keys for Embeddings
# OpenAI API Key (required when EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Cohere API Key (required when EMBEDDING_PROVIDER=cohere)
# COHERE_API_KEY=...
