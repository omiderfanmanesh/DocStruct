# LLM Provider: "anthropic" (default) or "azure"
LLM_PROVIDER=azure

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- Anthropic (alternative) ---
# ANTHROPIC_API_KEY=your-anthropic-key

# --- DocStruct settings ---
# DOCSTRUCT_MIN_CONFIDENCE=0.75
# DOCSTRUCT_BATCH_SIZE=5
# DOCSTRUCT_PARALLEL=true
# DOCSTRUCT_MAX_WORKERS=4
# DOCSTRUCT_AGENT_MODEL=claude-haiku-4-5-20251001
# DOCSTRUCT_AGENT_MAX_TOKENS=4096
# DOCSTRUCT_AGENT_TEMPERATURE=0.0
# DOCSTRUCT_AGENT_TIMEOUT=30
# DOCSTRUCT_AGENT_RETRY_COUNT=3
# DOCSTRUCT_AGENT_RETRY_DELAY=1
# DOCSTRUCT_AGENT_PROVIDER=anthropic
